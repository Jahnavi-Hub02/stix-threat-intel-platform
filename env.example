# ================================================================
# STIX Threat Intelligence Platform — Environment Configuration
# ================================================================
# Copy this file to .env and fill in your own values.
# Never commit .env to version control.
# ================================================================

# ── Application ────────────────────────────────────────────────
APP_NAME="STIX Threat Intelligence Platform"
APP_VERSION="2.5.0"
DEBUG=false

# ── Database (SQLite) ──────────────────────────────────────────
# The platform uses SQLite. DATABASE_URL is not used — only DB_PATH.
DB_PATH=database/threat_intel.db

# ── JWT Authentication (REQUIRED) ─────────────────────────────
# JWT_SECRET_KEY must be a long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: changing this key invalidates all existing sessions.
JWT_SECRET_KEY=81d572302226520cce9f6305804f3c2e13433504e5257b7453e720751065a265
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── TAXII Feed 1: AlienVault OTX (primary feed) ───────────────
FEED_1_NAME=AlienVault OTX
FEED_1_URL=https://otx.alienvault.com/taxii/taxii2/
FEED_1_AUTH=api_key
FEED_1_API_KEY=c65a73c6be844cf04217144ce94222a2a900ca65a2fe8fee27bc906954c097f5
FEED_1_ENABLED=true

# ── TAXII Feed 2: CISA AIS (US Gov free feed, no auth) ────────
FEED_2_NAME=CISA AIS
FEED_2_URL=https://ais2.cisa.dhs.gov/taxii2/
FEED_2_AUTH=none
FEED_2_ENABLED=false

# ── TAXII Feed 3: Anomali Limo (free tier) ────────────────────
FEED_3_NAME=Anomali Limo
FEED_3_URL=https://limo.anomali.com/api/v1/taxii2/feeds/
FEED_3_AUTH=basic
FEED_3_USERNAME=guest
FEED_3_PASSWORD=guest
FEED_3_ENABLED=false

# ── Scheduler ─────────────────────────────────────────────────
INGESTION_INTERVAL_MINUTES=30

# ── ML ────────────────────────────────────────────────────────
ML_MIN_TRAIN_SAMPLES=50
ML_RETRAIN_INTERVAL=100
ML_CONTAMINATION=0.05
ML_MODEL_DIR=models

# ── Reports ───────────────────────────────────────────────────
REPORT_OUTPUT_DIR=reports

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend (set this if deploying to a non-localhost URL) ───
FRONTEND_URL=http://localhost:5173