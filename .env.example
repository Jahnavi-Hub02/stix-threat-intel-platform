# ─────────────────────────────────────────────────────────────────
# STIX 2.1 Threat Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.
# ─────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────
# JWT signing secret. Use a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# ── JWT Token Lifetimes ───────────────────────────────────────────
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ── ML Configuration ──────────────────────────────────────────────
# Minimum number of events before the Isolation Forest auto-trains.
# Use 5 for development/testing; 50+ for production.
ML_MIN_TRAIN_SAMPLES=50
ML_CONTAMINATION=0.05
ML_MODEL_DIR=models
ML_RETRAIN_INTERVAL=100

# ── CORS ──────────────────────────────────────────────────────────
# Frontend URL added to CORS allowed origins
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────
# SQLite database location (created automatically on first run)
# DB_PATH=database/threat_intel.db

# ── Scheduler ─────────────────────────────────────────────────────
# TAXII ingestion interval in minutes
SCHEDULER_INTERVAL_MINUTES=30
